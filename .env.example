# Vire app runtime environment — root .env.example
#
# Copy this file to .env, fill in your local values, and source it into the
# shell that launches the app before running `npm run tauri:dev`.
#
# Apply command (the app reads process env; it does NOT auto-load .env):
#   set -a; . ./.env; set +a && npm run tauri:dev
#
# IMPORTANT: Do NOT commit .env — it is gitignored. This .env.example is the
# only file tracked. Never put real API keys in this file.
#
# This file configures the Vire DESKTOP APP.
# The Langfuse Docker stack has its own separate env at
# observability/langfuse/.env (server containers, Postgres/ClickHouse/Redis/
# MinIO bootstrap secrets) — do not mix these two files.

# ──────────────────────────────────────────────────────────────────────────────
# Langfuse connection (Vire app → local Langfuse)
# Default: local Docker stack on loopback (DEC-020). Works out of the box
# when the observability/langfuse/ Compose stack is running.
# ──────────────────────────────────────────────────────────────────────────────

VIRE_LANGFUSE_BASE_URL=http://127.0.0.1:3000
VIRE_LANGFUSE_SOURCE=local
VIRE_LANGFUSE_ENVIRONMENTS=vire

# Langfuse API credentials — create in the Langfuse UI under
# Project settings → API keys. Fill locally; NEVER commit.
# Fallback: the app also accepts LANGFUSE_PUBLIC_KEY / LANGFUSE_SECRET_KEY
# (bare names) if the VIRE_* names are not set.
VIRE_LANGFUSE_PUBLIC_KEY=
VIRE_LANGFUSE_SECRET_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Cloud override — uncomment BOTH lines to use Langfuse Cloud instead.
# Langfuse Cloud is an explicit, non-default override (DEC-020); the default
# source is local. Leave commented unless you are deliberately using Cloud.
# ──────────────────────────────────────────────────────────────────────────────

# VIRE_LANGFUSE_SOURCE=cloud
# VIRE_LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ──────────────────────────────────────────────────────────────────────────────
# Runtime reconciliation observer (optional — all have safe code defaults)
# ──────────────────────────────────────────────────────────────────────────────

# Explicit path to the pi-observe runtime session log.
# Default resolution: $PI_OBSERVE_STATE_DIR/events.jsonl → ~/.local/state/pi-observe/events.jsonl
# VIRE_RUNTIME_LOG_PATH=

# Directory from which events.jsonl is resolved (used by pi-observe infrastructure).
# Override only if your pi-observe state directory is non-standard.
# PI_OBSERVE_STATE_DIR=

# Map pi project tokens to Langfuse environments (CSV of token=env pairs).
# Example: VIRE_RUNTIME_ENV_MAP=myproject=vire,other=staging
# VIRE_RUNTIME_ENV_MAP=

# Time window slop in seconds for session/trace matching (default: 300).
# VIRE_RUNTIME_MATCH_SLOP_SECS=300
