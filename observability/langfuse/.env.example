# Local Langfuse configuration for Janne's development machine.
# Copy to .env and fill local-only secrets/API keys. Do not commit .env.

LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PORT=3000

# Create these in the Langfuse UI after first login: Project settings -> API keys.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_PROJECT_ID=

# Local stack secrets. setup-local-observability.sh can generate these in .env.
NEXTAUTH_SECRET=
SALT=
ENCRYPTION_KEY=

# Initial local admin bootstrap (change before first start if desired).
LANGFUSE_INIT_ORG_ID=local-janne
LANGFUSE_INIT_ORG_NAME=Janne-Local
LANGFUSE_INIT_PROJECT_ID=local-observability
LANGFUSE_INIT_PROJECT_NAME=Local-Observability
LANGFUSE_INIT_USER_EMAIL=janne@example.local
LANGFUSE_INIT_USER_NAME=Janne
LANGFUSE_INIT_USER_PASSWORD=

# Local backing services; passwords are local-only and generated by setup if missing.
POSTGRES_USER=langfuse
POSTGRES_PASSWORD=
POSTGRES_DB=langfuse
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=
REDIS_PASSWORD=
MINIO_ROOT_USER=langfuse
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=langfuse

# pi-observe wrapper defaults.
PI_OBSERVE_ENABLED=true
PI_OBSERVE_CAPTURE_RAW=false
PI_OBSERVE_IDLE_THRESHOLD_MS=300000
PI_OBSERVE_STATE_DIR=${HOME}/.local/state/pi-observe
PI_OBSERVE_CONFIG_DIR=${HOME}/.config/pi-observe
PI_OBSERVE_USER_ID=local-janne
PI_OBSERVE_LANGFUSE_TIMEOUT_MS=1200
